{
  "appId": "com.monokelvin.wanwu",
  "productName": "Wanwu",
  "copyright": "Copyright © 2026 MonoStudio",
  "directories": {
    "output": "release",
    "buildResources": "pack"
  },
  "files": [
    "out/**/*",
    "package.json",
    "!node_modules/**/{test,tests,__tests__,docs,doc,example,examples}/**",
    "!node_modules/**/*.{md,ts,map}"
  ],
  "npmRebuild": false,
  "asar": true,
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**/*.node",
    "**/node_modules/electron-native-share/**/*.node"
  ],
  "afterPack": "pack/windows/pack-lib.mjs",
  "extraResources": [
    { "from": "assets/logo", "to": "assets/logo" },
    { "from": "assets/cloud-abode/video", "to": "assets/cloud-abode/video" }
  ],
  "forceCodeSigning": false,
  "win": {
    "target": [{ "target": "dir", "arch": ["x64"] }],
    "icon": "pack/app.ico",
    "executableName": "Wanwu",
    "signAndEditExecutable": false
  }
}
