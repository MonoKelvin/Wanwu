{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@electron/*": ["electron/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "electron/**/*",
    "electron.vite.config.ts",
    "scripts/**/*",
    "src/shared/types/**/*",
    "src/shared/constants/**/*"
  ]
}
