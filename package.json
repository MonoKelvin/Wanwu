{
    "name": "wanwu",
    "version": "1.1.1",
    "type": "module",
    "description": "万物 - 事物收集与浏览桌面应用",
    "main": "out/main/index.js",
    "author": "MonoKelvin",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/MonoKelvin/Wanwu.git"
    },
    "scripts": {
        "dev": "node scripts/run.mjs dev && electron-vite dev",
        "build": "node scripts/run.mjs sqlite host && tsx scripts/build-library-pack.ts && electron-vite build && node scripts/run.mjs sqlite rebuild --force",
        "build:app": "node scripts/run.mjs sqlite host && electron-vite build && node scripts/run.mjs sqlite rebuild --force",
        "pack": "node scripts/run.mjs pack",
        "logo:ico": "node scripts/generate-app-ico.mjs",
        "typecheck": "vue-tsc --noEmit -p tsconfig.web.json",
        "postinstall": "node scripts/run.mjs sqlite rebuild",
        "rebuild": "node scripts/run.mjs sqlite rebuild --force"
    },
    "dependencies": {
        "@lucide/vue": "^1.16.0",
        "@primeuix/themes": "^2.0.3",
        "@vueuse/core": "^14.3.0",
        "archiver": "^8.0.0",
        "better-sqlite3": "^12.10.0",
        "electron-native-share": "^0.1.1",
        "extract-zip": "^2.0.1",
        "html2canvas": "^1.4.1",
        "marked": "^18.0.4",
        "pinia": "^3.0.4",
        "primevue": "^4.5.5",
        "rss-parser": "^3.13.0",
        "tailwindcss-primeui": "^0.6.1",
        "vue": "^3.5.34",
        "vue-router": "^5.0.7"
    },
    "devDependencies": {
        "@electron/rebuild": "^3.7.2",
        "@types/archiver": "^7.0.0",
        "@types/better-sqlite3": "^7.6.13",
        "@vitejs/plugin-vue": "^6.0.7",
        "autoprefixer": "^10.5.0",
        "electron": "^39.8.10",
        "electron-builder": "^26.8.1",
        "electron-vite": "^5.0.0",
        "lucide-vue-next": "^1.0.0",
        "png2icons": "^2.0.1",
        "postcss": "^8.5.15",
        "rcedit": "^5.0.2",
        "tailwindcss": "^3.4.19",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "vite": "^7.3.3",
        "vue-tsc": "^3.3.1"
    },
    "engines": {
        "node": ">=20.19.0 || >=22.12.0"
    }
}
