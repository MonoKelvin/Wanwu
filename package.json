{
  "name": "wanwu",
  "version": "1.0.1",
  "type": "module",
  "description": "万物 - 事物收集与浏览桌面应用",
  "main": "out/main/index.js",
  "author": "MonoKelvin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MonoKelvin/Wanwu.git"
  },
  "scripts": {
    "dev": "node scripts/check-node.mjs && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json",
    "seed:import": "tsx scripts/seed-import.ts",
    "seed:library": "node scripts/seed-library-media.mjs",
    "seed:library:catalog": "node scripts/build-library-catalog.mjs",
    "seed:library:media": "node scripts/seed-library-media.mjs",
    "seed:library:sync-media": "node scripts/sync-library-media-manifest.mjs",
    "seed:library:retry-media": "node scripts/retry-missing-library-media.mjs",
    "seed:library:audit": "node scripts/audit-library-media.mjs",
    "seed:library:reimport": "tsx scripts/reimport-library-catalog.ts",
    "seed:library:legacy-unsplash": "node scripts/seed-library.mjs",
    "seed:library:attribution": "node scripts/enrich-library-attribution.mjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@vueuse/core": "^14.3.0",
    "better-sqlite3": "^12.10.0",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.3",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "rss-parser": "^3.13.0",
    "tailwindcss-primeui": "^0.6.1",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "electron": "^39.8.10",
    "electron-builder": "^26.10.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vue-tsc": "^3.3.0"
  },
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  }
}
