{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./src/app/*"],
      "@modules/*": ["./src/modules/*"],
      "@library/*": ["./src/modules/library/core/*"],
      "@renderer/*": ["./src/renderer/*"],
      "@features/*": ["./src/modules/*"],
      "@shared/*": ["./src/shared/*"],
      "@assets/*": ["./assets/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/**/*.d.ts"]
}
