{
  "version": 2,
  "defaults": {
    "provider": "pixabay",
    "imageType": "photo",
    "orientation": "all",
    "minMatchScore": 1,
    "perPage": 24
  },
  "providers": {
    "pixabay": {
      "envKey": "PIXABAY_API_KEY",
      "docs": "https://pixabay.com/api/docs/"
    },
    "unsplash": {
      "envKey": "UNSPLASH_ACCESS_KEY",
      "docs": "https://unsplash.com/developers"
    },
    "manual": {
      "note": "将 cover.jpg、gallery-01~03.jpg 放入 assets/library/{categoryId}/{slug}/"
    }
  },
  "items": {
    "cat-british-shorthair": {
      "query": "british shorthair cat portrait",
      "category": "animals",
      "matchTags": ["cat", "shorthair", "british"]
    },
